pipeline {
    agent {label 'agent-1'}
      
    stages {
        stage('clone') {
            steps {
                   cleanWs()
                sh 'git clone https://github.com/mahadevlakhera/my-java-app.git'
            }
        }
        stage('build') {
            steps {
                   sh'''
                     cd java-proj-sprng
                     mvn package
                     '''
             
            }
        }
    }
}
